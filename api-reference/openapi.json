      "V1TransactionType": {
        "type": "object",
        "description": "UAE transaction-type flags (BTAE-02 / ProfileExecutionID). Each boolean maps to one bit in the 8-character binary string emitted by the platform. Omit the object entirely (or pass all false) for a standard invoice (\"00000000\").",
