            "description": "Bit 1 — Free Trade Zone supply.",
            "default": false
          },
          "deemedSupply": {
            "type": "boolean",
            "description": "Bit 2 — Deemed supply.",
            "default": false
          },
          "profitMargin": {
            "type": "boolean",
            "description": "Bit 3 — Profit margin scheme.",
            "default": false
          },
          "summaryInvoice": {
            "type": "boolean",
            "description": "Bit 4 — Summary invoice covering a billing period. Requires billingPeriodStart and billingPeriodEnd.",
            "default": false
          },
          "continuousSupply": {
            "type": "boolean",
            "description": "Bit 5 — Continuous supply. Requires billingFrequencyCode.",
            "default": false
          },
          "disclosedAgentBilling": {
            "type": "boolean",
            "description": "Bit 6 — Disclosed agent billing. Requires principalId.",
            "default": false
          },
          "ecommerce": {
            "type": "boolean",
            "description": "Bit 7 — E-commerce supply.",
            "default": false
          },
          "exports": {
            "type": "boolean",
            "description": "Bit 8 — Export supply.",
            "default": false
          }
        },
        "default": null,
        "nullable": true
      },
