  "components": {
    "schemas": {
      "V1AdditionalDocument": {
        "required": [
          "documentId"
        ],
        "type": "object",
        "properties": {
          "documentId": {
            "type": "string"
          },
          "documentTypeCode": {
            "type": "string",
            "default": null,
            "nullable": true
          },
          "description": {
            "type": "string",
            "default": null,
            "nullable": true
          },
          "externalUri": {
            "type": "string",
            "default": null,
            "nullable": true
          },
          "embeddedBase64": {
            "type": "string",
            "default": null,
            "nullable": true
          },
          "mimeCode": {
            "type": "string",
            "default": null,
            "nullable": true
          },
          "fileName": {
            "type": "string",
            "default": null,
            "nullable": true
          }
        }
      },
      "V1Address": {
        "required": [
          "line1",
          "city",
          "countryCode"
        ],
        "type": "object",
        "properties": {
          "line1": {
            "type": "string",
            "nullable": true
          },
          "city": {
            "type": "string",
            "nullable": true
          },
          "countryCode": {
            "type": "string",
            "nullable": true
          },
          "line2": {
            "type": "string",
            "description": "Second address line (BT-51 / building number, suite, floor).",
            "default": null,
            "nullable": true
          },
          "countrySubentity": {
            "type": "string",
            "description": "State, emirate, or province code (BT-54 / cbc:CountrySubentity).",
            "default": null,
            "nullable": true
          },
          "postalCode": {
            "type": "string",
            "description": "Postal / ZIP code (BT-53 / cbc:PostalZone).",
            "default": null,
            "nullable": true
          }
        },
        "nullable": true
      },
      "V1AllowanceCharge": {
        "required": [
          "isCharge",
          "amount"
        ],
        "type": "object",
        "properties": {
          "isCharge": {
            "type": "boolean"
          },
          "amount": {
            "type": "number",
            "format": "double"
          },
          "reasonCode": {
            "type": "string",
            "default": null,
            "nullable": true
          },
          "reason": {
            "type": "string",
            "default": null,
            "nullable": true
          },
          "baseAmount": {
            "type": "number",
            "format": "double",
            "default": null,
            "nullable": true
          },
          "multiplierPercent": {
            "type": "number",
            "format": "double",
            "default": null,
            "nullable": true
          },
          "vatCategory": {
            "type": "string",
            "default": null,
            "nullable": true
          },
          "vatRate": {
            "type": "number",
            "format": "double",
            "default": null,
            "nullable": true
          },
          "exemptionReasonCode": {
            "type": "string",
            "default": null,
            "nullable": true
          }
        }
      },
      "V1CreateInvoiceRequest": {
        "required": [
          "documentType",
          "invoiceNumber",
          "issueDate",
          "dueDate",
          "currency",
          "seller",
          "buyer",
          "lines",
          "references",
          "notes",
          "precedingInvoiceNumber"
        ],
        "type": "object",
        "properties": {
          "documentType": {
            "type": "string"
          },
          "invoiceNumber": {
            "type": "string",
            "nullable": true
          },
          "issueDate": {
            "type": "string",
            "format": "date"
          },
          "dueDate": {
            "type": "string",
            "format": "date",
            "nullable": true
          },
          "currency": {
            "type": "string",
            "nullable": true
          },
          "seller": {
            "$ref": "#/components/schemas/V1Party"
          },
          "buyer": {
            "$ref": "#/components/schemas/V1Party"
          },
          "lines": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/V1InvoiceLine"
            }
          },
          "references": {
            "$ref": "#/components/schemas/V1References"
          },
          "notes": {
            "type": "string",
            "nullable": true
          },
          "precedingInvoiceNumber": {
            "type": "string",
            "nullable": true
          },
          "taxTotal": {
            "$ref": "#/components/schemas/V1TaxTotal"
          },
          "legalMonetaryTotal": {
            "$ref": "#/components/schemas/V1LegalMonetaryTotal"
          },
          "allowancesCharges": {
            "type": "array",
            "items": {},
            "default": null,
            "nullable": true
          },
          "additionalDocuments": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/V1AdditionalDocument"
            },
            "default": null,
            "nullable": true
          },
          "delivery": {
            "$ref": "#/components/schemas/V1Delivery"
          },
          "transactionType": {
            "$ref": "#/components/schemas/V1TransactionType"
          },
          "beneficiaryId": {
            "type": "string",
            "description": "Beneficiary ID (BTAE-01). Required by the platform when transactionType.freeTradeZone is true.",
            "default": null,
            "nullable": true
          },
          "principalId": {
            "type": "string",
            "description": "Principal / Disclosed-Agent ID (BTAE-14). Required when transactionType.disclosedAgentBilling is true.",
            "default": null,
            "nullable": true
          },
          "billingFrequencyCode": {
            "type": "string",
            "description": "Billing frequency code (IBT-020). Required for summaryInvoice and continuousSupply transaction types.",
            "default": null,
            "nullable": true
          },
          "taxCurrencyCode": {
            "type": "string",
            "description": "Tax currency code (ibr-140-ae). Always \"AED\" when invoice currency differs from AED.",
            "default": null,
            "nullable": true
          },
          "currencyExchangeRate": {
            "type": "number",
            "format": "double",
            "description": "Exchange rate: AED per 1 unit of the invoice currency (BTAE-04 / ibr-159-ae). Required when currency is not AED. Maximum 6 decimal places.",
            "default": null,
            "nullable": true
          },
          "paymentMode": {
            "type": "string",
            "description": "Payment means type code (BT-81 / cbc:PaymentMeansCode), e.g. \"10\" cash, \"30\" credit transfer, \"48\" card.",
            "default": null,
            "nullable": true
          },
          "paymentTerms": {
            "type": "string",
            "description": "Free-text payment terms note (BT-20 / cbc:Note under cac:PaymentTerms).",
            "default": null,
            "nullable": true
          },
          "paymentBankAccount": {
            "type": "string",
            "description": "Bank account identifier for payment (cbc:ID under cac:FinancialAccount), e.g. IBAN.",
            "default": null,
            "nullable": true
          },
          "vatPointDate": {
            "type": "string",
            "format": "date",
            "description": "VAT point date (BT-7 / ibr-141-ae). Must be before issueDate; not allowed on credit notes.",
            "default": null,
            "nullable": true
          },
          "billingPeriodStart": {
            "type": "string",
            "format": "date",
            "description": "Start of the billing period (IBG-14 / ibr-138-ae). Required when transactionType.summaryInvoice is true.",
            "default": null,
            "nullable": true
          },
          "billingPeriodEnd": {
            "type": "string",
            "format": "date",
            "description": "End of the billing period (IBG-14). Required when transactionType.summaryInvoice is true.",
            "default": null,
            "nullable": true
          },
          "precedingInvoiceIssueDate": {
            "type": "string",
            "format": "date",
            "description": "Issue date of the original invoice being credited (BT-26). Used on credit notes.",
            "default": null,
            "nullable": true
          }
        }
      },
      "V1CreateWebhookRequest": {
        "required": [
          "targetUrl",
          "eventTypes"
        ],
        "type": "object",
        "properties": {
          "targetUrl": {
            "type": "string"
          },
          "eventTypes": {
            "type": "array",
            "items": {
              "type": "string"
